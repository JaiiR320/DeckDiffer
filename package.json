{
  "name": "deckdiff",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:api": "pnpm --filter @deckdiff/api dev",
    "dev:web": "pnpm --filter @deckdiff/web dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "verify": "pnpm fmt:check && pnpm lint && pnpm check && pnpm test && pnpm build",
    "sandcastle": "pnpm exec tsx .sandcastle/main.ts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "beta",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
