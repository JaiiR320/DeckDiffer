{
  "name": "deckdiff",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:api": "pnpm --filter @deckdiff/api dev",
    "dev:web": "pnpm --filter @deckdiff/web dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "tagger:fetch": "tsx scripts/fetch-tagger-tags.ts",
    "test": "vitest run",
    "verify": "pnpm fmt:check && pnpm lint && pnpm check && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@typescript/native-preview": "beta",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.64.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.33.2"
}
